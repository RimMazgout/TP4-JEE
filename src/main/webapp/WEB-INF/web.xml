<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ==================== SERVLETS ==================== -->

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.gestion.web.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.gestion.web.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ListProduitServlet</servlet-name>
        <servlet-class>com.gestion.web.ListProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListProduitServlet</servlet-name>
        <url-pattern>/produits</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddProduitServlet</servlet-name>
        <servlet-class>com.gestion.web.AddProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddProduitServlet</servlet-name>
        <url-pattern>/addProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteProduitServlet</servlet-name>
        <servlet-class>com.gestion.web.DeleteProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteProduitServlet</servlet-name>
        <url-pattern>/deleteProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EditProduitServlet</servlet-name>
        <servlet-class>com.gestion.web.EditProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditProduitServlet</servlet-name>
        <url-pattern>/editProduit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateProduitServlet</servlet-name>
        <servlet-class>com.gestion.web.UpdateProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateProduitServlet</servlet-name>
        <url-pattern>/updateProduit</url-pattern>
    </servlet-mapping>

    <!-- ==================== FILTRES ==================== -->

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.gestion.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>RoleFilter</filter-name>
        <filter-class>com.gestion.filter.RoleFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/addProduit</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/deleteProduit</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/editProduit</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>RoleFilter</filter-name>
        <url-pattern>/updateProduit</url-pattern>
    </filter-mapping>

    <!-- ==================== ERREURS ==================== -->

    <error-page>
        <error-code>403</error-code>
        <location>/error403.jsp</location>
    </error-page>

    <error-page>
        <error-code>404</error-code>
        <location>/error404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error500.jsp</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Exception</exception-type>
        <location>/error500.jsp</location>
    </error-page>

    <!-- ==================== ACCUEIL ==================== -->

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

</web-app>